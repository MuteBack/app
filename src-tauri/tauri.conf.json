{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MuteBack",
  "version": "0.1.0",
  "identifier": "com.muteback.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MuteBack",
        "width": 280,
        "height": 190,
        "minWidth": 280,
        "minHeight": 190,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://updates.example.com/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_UPDATER_PUBKEY"
    }
  },
  "bundle": {
    "active": false
  }
}
