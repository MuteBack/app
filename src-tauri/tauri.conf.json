{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MuteBack",
  "version": "1.1.1",
  "identifier": "com.muteback.app",
  "mainBinaryName": "MuteBack_x64",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MuteBack",
        "width": 280,
        "height": 190,
        "minWidth": 280,
        "minHeight": 190,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MuteBack/app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1Q0VCM0VDMTE4RDI3OEEKUldTS0o0MFI3TFBPZFZYcE5nY2pIMUVVYjdkaHIrTTZpOEtyQVFRc2t6U0YxY3E3M2hWRDdseC8K",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "../assets/vendor/silero_vad.onnx": "assets/vendor/silero_vad.onnx",
      "../assets/vendor/voxceleb_ECAPA512_LM.onnx": "assets/vendor/voxceleb_ECAPA512_LM.onnx",
      "../assets/vendor/onnxruntime-win-x64-1.24.2/onnxruntime-win-x64-1.24.2/lib/onnxruntime.dll": "assets/vendor/onnxruntime.dll",
      "../assets/vendor/onnxruntime-win-x64-1.24.2/onnxruntime-win-x64-1.24.2/lib/onnxruntime_providers_shared.dll": "assets/vendor/onnxruntime_providers_shared.dll"
    }
  }
}
