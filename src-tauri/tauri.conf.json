{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MuteBack",
  "version": "0.1.0",
  "identifier": "com.muteback.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MuteBack",
        "width": 360,
        "height": 290,
        "minWidth": 360,
        "minHeight": 290,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
